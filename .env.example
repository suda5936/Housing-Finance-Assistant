# Application
APP_ENV=development
APP_NAME=homefit-ai
LOG_LEVEL=INFO

# API
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database
POSTGRES_DB=homefit
POSTGRES_USER=homefit
POSTGRES_PASSWORD=local_homefit_password
DATABASE_URL=postgresql+psycopg://homefit:local_homefit_password@localhost:5432/homefit

# Local file handling
UPLOAD_DIR=.local-data/uploads
DOCUMENT_RETENTION_HOURS=24

# Local LLM (no paid API key required)
LLM_PROVIDER=ollama
LLM_ENABLED=true
LLM_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_CONTEXT_TOKENS=8192
LLM_MAX_OUTPUT_TOKENS=1024
LLM_TIMEOUT_SECONDS=30
OCR_ENABLED=false
OCR_PROVIDER=mock
OCR_API_KEY=
MAP_PROVIDER=manual
MAP_API_KEY=
