# Application
APP_ENV=development
APP_NAME=homefit-ai
LOG_LEVEL=INFO

# API
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database
POSTGRES_DB=homefit
POSTGRES_USER=homefit
POSTGRES_PASSWORD=local_homefit_password
DATABASE_URL=postgresql+psycopg://homefit:local_homefit_password@localhost:5432/homefit

# Local file handling
UPLOAD_DIR=.local-data/uploads
DOCUMENT_RETENTION_HOURS=24

# External providers: keep mock until a provider is explicitly selected.
LLM_PROVIDER=mock
LLM_API_KEY=
OCR_PROVIDER=mock
OCR_API_KEY=
MAP_PROVIDER=manual
MAP_API_KEY=

